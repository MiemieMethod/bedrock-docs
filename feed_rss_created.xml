<?xml version="1.0" encoding="UTF-8" ?> <?xml-stylesheet type="text/xsl" href="rss.xsl"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:dc="http://purl.org/dc/elements/1.1/"> <channel> <title>基岩文档</title><description>Minecraft基岩版开发文档</description><link>https://miemiemethod.github.io/bedrock-docs/</link><atom:link href="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml" rel="self" type="application/rss+xml" /> <docs>https://github.com/MiemieMethod/bedrock-docs</docs><language>zh</language> <pubDate>Sun, 24 May 2026 05:14:57 -0000</pubDate> <lastBuildDate>Sun, 24 May 2026 05:14:57 -0000</lastBuildDate> <ttl>1440</ttl> <generator>MkDocs RSS plugin - v1.19.0</generator> <image> <url>None</url> <title>基岩文档</title> <link>https://miemiemethod.github.io/bedrock-docs/</link> </image> <item> <title>技术</title> <description>&lt;h1&gt;技术&lt;/h1&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/blog/category/%E6%8A%80%E6%9C%AF/</link> <pubDate>Sun, 24 May 2026 05:18:54 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/blog/category/%E6%8A%80%E6%9C%AF/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/blog/category/技术.png" type="image/png" length="10425" /> </item> <item> <title>2024</title> <description>&lt;h1&gt;2024&lt;/h1&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/blog/archive/2024/</link> <pubDate>Sun, 24 May 2026 05:18:54 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/blog/archive/2024/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/blog/archive/2024.png" type="image/png" length="12772" /> </item> <item> <title>官方自动导出的文档</title> <description>&lt;h1&gt;官方自动导出的文档翻译&lt;/h1&gt; &lt;p&gt;本页收录“官方自动导出的文档”知识库目录中的Markdown说明文件翻译与整理，用于标注该资料源的来源、维护方式与使用边界。&lt;/p&gt; &lt;ul&gt; &lt;li&gt;原始仓库：&lt;a href=&#34;https://github.com/bedrock-dot-dev/docs&#34;&gt;https://github.com/bedrock-dot-dev/docs&lt;/a&gt;&lt;/li&gt; &lt;li&gt;当前整理来源：`.knowledge\官方自动导出的文...&lt;/li&gt; &lt;/ul&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/translations/official-export/</link> <pubDate>Sun, 24 May 2026 05:12:47 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/translations/official-export/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/translations/official-export/index.png" type="image/png" length="10713" /> </item> <item> <title>客户端模组</title> <description>&lt;h1&gt;客户端模组&lt;/h1&gt; &lt;p&gt;&lt;strong&gt;客户端模组（Client Mod）&lt;/strong&gt;是运行在Minecraft基岩版客户端侧、直接扩展或修改客户端行为的一类模组形态。与附加包和服务端插件相比，客户端模组通常依赖特定加载器、特定系统环境和特定游戏版本，兼容性边界更严格。&lt;/p&gt; &lt;h2&gt;概述&lt;/h2&gt; &lt;p&gt;在基岩版历史生态中，客户端模组主要以Android平...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/client/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/client/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/client/index.png" type="image/png" length="10553" /> </item> <item> <title>CoreEngine</title> <description>&lt;h1&gt;CoreEngine&lt;/h1&gt; &lt;p&gt;&lt;strong&gt;CoreEngine（CoreEngine）&lt;/strong&gt;是InnerCore生态中向模组暴露主要能力接口的运行引擎层。模组通常通过CoreEngine提供的对象、方法与回调机制访问世界、实体、界面与事件等功能。&lt;/p&gt; &lt;h2&gt;职责&lt;/h2&gt; &lt;p&gt;CoreEngine的核心职责是为模组提供一致的可编程接口，并...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/client/coreengine/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/client/coreengine/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/client/coreengine.png" type="image/png" length="17245" /> </item> <item> <title>Horizon启动器</title> <description>&lt;h1&gt;Horizon启动器&lt;/h1&gt; &lt;p&gt;&lt;strong&gt;Horizon启动器（Horizon Launcher）&lt;/strong&gt;是InnerCore生态中用于安装、管理和启动模组包的客户端程序。该启动器在旧客户端模组流程中承担入口角色，负责将模组包与游戏运行环境连接起来。&lt;/p&gt; &lt;h2&gt;功能&lt;/h2&gt; &lt;p&gt;Horizon启动器通常提供以下能力：&lt;/p&gt; &lt;ul&gt; &lt;li&gt;下载与安装不同...&lt;/li&gt; &lt;/ul&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/client/horizon/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/client/horizon/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/client/horizon.png" type="image/png" length="14538" /> </item> <item> <title>InnerCore</title> <description>&lt;h1&gt;InnerCore&lt;/h1&gt; &lt;p&gt;&lt;strong&gt;InnerCore（InnerCore）&lt;/strong&gt;是面向Android版Minecraft基岩版的传统客户端模组框架。其核心目标是为第三方模组提供统一运行层，使开发者能够在客户端侧使用脚本、Java与原生代码扩展玩法与界面能力。&lt;/p&gt; &lt;h2&gt;定位&lt;/h2&gt; &lt;p&gt;InnerCore属于历史社区生态，不属于M...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/client/innercore/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/client/innercore/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/client/innercore.png" type="image/png" length="15017" /> </item> <item> <title>InnerCore客户端模组</title> <description>&lt;h1&gt;InnerCore客户端模组&lt;/h1&gt; &lt;p&gt;本分区以InnerCore、CoreEngine和Horizon为中心，整理Android客户端旧模组生态的可核验资料。Nernar维护的InnerCore文档说明，InnerCore扩展Android版Minecraft的基础功能，用于创建会改变玩法的模组；它的思路与Bloc...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/clients/innercore/index.png" type="image/png" length="17189" /> </item> <item> <title>准备环境与项目结构</title> <description>&lt;h1&gt;准备环境与项目结构&lt;/h1&gt; &lt;p&gt;ICMod开发以Android设备上的Horizon启动器为入口。Nernar维护的InnerCore文档把整体关系描述为“Horizon加载InnerCore包，InnerCore包加载CoreEngine，模组再通过CoreEngine与Minecraft交互”。这个体系属于第三方旧...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/environment-and-structure/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/environment-and-structure/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/clients/innercore/environment-and-structure.png" type="image/png" length="10713" /> </item> <item> <title>事件、存储与多人</title> <description>&lt;h1&gt;事件、存储与多人&lt;/h1&gt; &lt;p&gt;InnerCore的运行逻辑主要围绕回调、可更新对象、保存作用域和网络包组织。资料将这些机制用于旧Android客户端模组中的交互、长期机制、配置保存和多人同步。&lt;/p&gt; &lt;p&gt;/// warning | 服务端权威原则 InnerCore资料把单人世界的主机也视作服务端。所有会影响世界、玩家数据或重...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/events-storage-and-multiplayer/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/events-storage-and-multiplayer/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/clients/innercore/events-storage-and-multiplayer.png" type="image/png" length="10747" /> </item> <item> <title>物品、方块与配方</title> <description>&lt;h1&gt;物品、方块与配方&lt;/h1&gt; &lt;p&gt;InnerCore的物品、方块与配方系统使用JavaScript或TypeScript脚本注册内容，并由资源目录提供纹理。这里的能力属于旧第三方客户端模组生态，不是国际版附加包原生格式。&lt;/p&gt; &lt;p&gt;/// warning | 不要混淆开发体系 本文出现的&lt;code&gt;IDRegistry&lt;/code&gt;、&lt;code&gt;Item&lt;/code&gt;、`B...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/items-blocks-and-recipes/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/items-blocks-and-recipes/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/clients/innercore/items-blocks-and-recipes.png" type="image/png" length="10747" /> </item> <item> <title>界面、环境与库</title> <description>&lt;h1&gt;界面、环境与库&lt;/h1&gt; &lt;p&gt;Nernar维护的InnerCore文档还包含旧界面系统、区块源、粒子、维度、库和变更记录资料。本页只整理知识库中正文较完整的部分，并明确说明资料不足之处。&lt;/p&gt; &lt;h2&gt;世界访问对象&lt;/h2&gt; &lt;p&gt;InnerCore资料使用&lt;code&gt;BlockSource&lt;/code&gt;表示对世界区域的访问。它按维度或上下文取得，适合读取和修改...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/ui-environment-and-libraries/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/ui-environment-and-libraries/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/clients/innercore/ui-environment-and-libraries.png" type="image/png" length="10639" /> </item> <item> <title>Endstone入门</title> <description>&lt;h1&gt;Endstone入门&lt;/h1&gt; &lt;p&gt;Endstone为官方BDS提供第三方插件API，支持Python和C++插件。它适合想保留BDS行为，又希望用较高层接口扩展服务器的人。本文只说明Endstone生态的使用方式，不把Endstone能力视为BDS原生能力。&lt;/p&gt; &lt;p&gt;/// info | 本系列后续页面 - [Endston...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/servers/endstone/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/servers/endstone/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/servers/endstone/index.png" type="image/png" length="17955" /> </item> <item> <title>命令、事件与调度实战</title> <description>&lt;h1&gt;Endstone命令、事件与调度实战&lt;/h1&gt; &lt;p&gt;当你已经能加载插件后，下一步通常就是把“交互入口”补齐：命令负责输入，事件负责触发，调度器负责周期行为。这篇教程给出一套最常见的组合方式。&lt;/p&gt; &lt;h2&gt;命令：先做一个可扩展骨架&lt;/h2&gt; &lt;p&gt;先声明&lt;code&gt;commands&lt;/code&gt;和&lt;code&gt;permissions&lt;/code&gt;，再在&lt;code&gt;on_command&lt;/code&gt;中分发逻辑...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/servers/endstone/command-event-task/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/servers/endstone/command-event-task/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/servers/endstone/command-event-task.png" type="image/png" length="10871" /> </item> <item> <title>Python插件工作流</title> <description>&lt;h1&gt;EndstonePython插件工作流&lt;/h1&gt; &lt;p&gt;这篇教程把官方文档中的“创建插件→安装插件→发布插件”三段流程串成一条可执行路线。你可以把它当成日常开发清单，按顺序做完就能从空项目走到可发布插件。&lt;/p&gt; &lt;h2&gt;步骤1：先准备一个可复用环境&lt;/h2&gt; &lt;p&gt;先创建虚拟环境并安装Endstone。后续写插件、调试插件、构建插件都在这个环...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/servers/endstone/python-plugin-workflow/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/servers/endstone/python-plugin-workflow/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/servers/endstone/python-plugin-workflow.png" type="image/png" length="16308" /> </item> <item> <title>基岩版命令更新记录</title> <description>&lt;h1&gt;基岩版命令更新记录&lt;/h1&gt; &lt;p&gt;本页基于ProjectXero维护的《Minecraft基岩版命令更新日志》进行中文整理，面向命令迁移、函数兼容性校验与教程版本标注。&lt;/p&gt; &lt;ul&gt; &lt;li&gt;原始项目：&lt;a href=&#34;https://github.com/XeroAlpha/Minecraft-Bedrock-Command-Log&#34;&gt;https://github.com/XeroAlpha/Minecraft-Bedrock-Command-Log&lt;/a&gt;&lt;/li&gt; &lt;li&gt;当前整理来...&lt;/li&gt; &lt;/ul&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/translations/command-log/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/translations/command-log/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/translations/command-log/index.png" type="image/png" length="10713" /> </item> <item> <title>Minecraft - 1.21.131（基岩版）</title> <description>&lt;p&gt;&lt;strong&gt;发布时间&lt;/strong&gt;：2025年12月16日&lt;/p&gt; &lt;p&gt;该修复版用于处理上一版本中发现的问题，将按平台逐步推送。&lt;/p&gt; &lt;h1&gt;修复 {#fixes}&lt;/h1&gt; &lt;h2&gt;常规 {#general}&lt;/h2&gt; &lt;ul&gt; &lt;li&gt;修复了在PC平台中，访问少于17个生物群系时仍可能解锁“探索时光”成就的问题（[MCPE-156784](https://bugs.moja...&lt;/li&gt; &lt;/ul&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/translations/help-center/changelogs/Minecraft-1-21-131-Bedrock/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/translations/help-center/changelogs/Minecraft-1-21-131-Bedrock/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/translations/help-center/changelogs/Minecraft-1-21-131-Bedrock.png" type="image/png" length="23375" /> </item> <item> <title>Minecraft基岩版26.20更新日志（开发向节选）</title> <description>&lt;p&gt;&lt;strong&gt;发布时间&lt;/strong&gt;：2026年5月5日&lt;/p&gt; &lt;p&gt;/// note | 说明 本页为开发相关重点节选翻译，完整条目请以[官方原文](https://feedback.minecraft.net/hc/en-us/articles/45400537384333-Minecraft-Bedrock-Edition-26-20-...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/translations/help-center/changelogs/Minecraft-Bedrock-Edition-26-20-Changelog/</link> <pubDate>Sun, 24 May 2026 04:50:31 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_created.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/translations/help-center/changelogs/Minecraft-Bedrock-Edition-26-20-Changelog/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/translations/help-center/changelogs/Minecraft-Bedrock-Edition-26-20-Changelog.png" type="image/png" length="24722" /> </item> <item> <title>Minecraft基岩版26.21修复版</title> <description>&lt;p&gt;&lt;strong&gt;发布时间&lt;/strong&gt;：2026年5月14日&lt;/p&gt; &lt;p&gt;新的修复版正在逐平台推送，用于处理上一次更新中发现的问题。由于各平台审核节奏不同，更新时间可能存在延迟。&lt;/p&gt; &lt;h1&gt;修复&lt;/h1&gt; &lt;h2&gt;游戏玩法&lt;/h2&gt; &lt;ul&gt; &lt;li&gt;包含多项错误修复与稳定性改进。&lt;/li&gt; &lt;/ul&gt; &lt;h2&gt;用户界面&lt;/h2&gt; &lt;ul&gt; &lt;li&gt;修复了在没有可用配方时打开熔炉导致卡死的问题。&lt;/li&gt; &lt;/ul&gt; &lt;h2&gt;稳定性与性能&lt;/h2&gt; &lt;p&gt;-...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/translations/hel