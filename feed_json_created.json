ec4\u901a\u5e38\u4f9d\u8d56\u7279\u5b9a\u52a0\u8f7d\u5668\u3001\u7279\u5b9a\u7cfb\u7edf\u73af\u5883\u548c\u7279\u5b9a\u6e38\u620f\u7248\u672c\uff0c\u517c\u5bb9\u6027\u8fb9\u754c\u66f4\u4e25\u683c\u3002</p>\n<h2>\u6982\u8ff0</h2>\n<p>\u5728\u57fa\u5ca9\u7248\u5386\u53f2\u751f\u6001\u4e2d\uff0c\u5ba2\u6237\u7aef\u6a21\u7ec4\u4e3b\u8981\u4ee5Android\u5e73...</p>", "image": "https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/client/index.png", "date_modified": "2026-05-24T04:50:31+00:00", "date_published": "2026-05-24T04:50:31+00:00", "authors": [], "tags": null}, {"id": "https://miemiemethod.github.io/bedrock-docs/docs/client/coreengine/", "url": "https://miemiemethod.github.io/bedrock-docs/docs/client/coreengine/", "title": "CoreEngine", "content_html": "<h1>CoreEngine</h1>\n<p><strong>CoreEngine\uff08CoreEngine\uff09</strong>\u662fInnerCore\u751f\u6001\u4e2d\u5411\u6a21\u7ec4\u66b4\u9732\u4e3b\u8981\u80fd\u529b\u63a5\u53e3\u7684\u8fd0\u884c\u5f15\u64ce\u5c42\u3002\u6a21\u7ec4\u901a\u5e38\u901a\u8fc7CoreEngine\u63d0\u4f9b\u7684\u5bf9\u8c61\u3001\u65b9\u6cd5\u4e0e\u56de\u8c03\u673a\u5236\u8bbf\u95ee\u4e16\u754c\u3001\u5b9e\u4f53\u3001\u754c\u9762\u4e0e\u4e8b\u4ef6\u7b49\u529f\u80fd\u3002</p>\n<h2>\u804c\u8d23</h2>\n<p>CoreEngine\u7684\u6838\u5fc3\u804c\u8d23\u662f\u4e3a\u6a21\u7ec4\u63d0\u4f9b\u4e00\u81f4\u7684\u53ef\u7f16\u7a0b\u63a5\u53e3\uff0c\u5e76...</p>", "image": "https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/client/coreengine.png", "date_modified": "2026-05-24T04:50:31+00:00", "date_published": "2026-05-24T04:50:31+00:00", "authors": [], "tags": null}, {"id": "https://miemiemethod.github.io/bedrock-docs/docs/client/horizon/", "url": "https://miemiemethod.github.io/bedrock-docs/docs/client/horizon/", "title": "Horizon\u542f\u52a8\u5668", "content_html": "<h1>Horizon\u542f\u52a8\u5668</h1>\n<p><strong>Horizon\u542f\u52a8\u5668\uff08Horizon Launcher\uff09</strong>\u662fInnerCore\u751f\u6001\u4e2d\u7528\u4e8e\u5b89\u88c5\u3001\u7ba1\u7406\u548c\u542f\u52a8\u6a21\u7ec4\u5305\u7684\u5ba2\u6237\u7aef\u7a0b\u5e8f\u3002\u8be5\u542f\u52a8\u5668\u5728\u65e7\u5ba2\u6237\u7aef\u6a21\u7ec4\u6d41\u7a0b\u4e2d\u627f\u62c5\u5165\u53e3\u89d2\u8272\uff0c\u8d1f\u8d23\u5c06\u6a21\u7ec4\u5305\u4e0e\u6e38\u620f\u8fd0\u884c\u73af\u5883\u8fde\u63a5\u8d77\u6765\u3002</p>\n<h2>\u529f\u80fd</h2>\n<p>Horizon\u542f\u52a8\u5668\u901a\u5e38\u63d0\u4f9b\u4ee5\u4e0b\u80fd\u529b\uff1a</p>\n<ul>\n<li>\u4e0b\u8f7d\u4e0e\u5b89\u88c5\u4e0d\u540c...</li>\n</ul>", "image": "https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/client/horizon.png", "date_modified": "2026-05-24T04:50:31+00:00", "date_published": "2026-05-24T04:50:31+00:00", "authors": [], "tags": null}, {"id": "https://miemiemethod.github.io/bedrock-docs/docs/client/innercore/", "url": "https://miemiemethod.github.io/bedrock-docs/docs/client/innercore/", "title": "InnerCore", "content_html": "<h1>InnerCore</h1>\n<p><strong>InnerCore\uff08InnerCore\uff09</strong>\u662f\u9762\u5411Android\u7248Minecraft\u57fa\u5ca9\u7248\u7684\u4f20\u7edf\u5ba2\u6237\u7aef\u6a21\u7ec4\u6846\u67b6\u3002\u5176\u6838\u5fc3\u76ee\u6807\u662f\u4e3a\u7b2c\u4e09\u65b9\u6a21\u7ec4\u63d0\u4f9b\u7edf\u4e00\u8fd0\u884c\u5c42\uff0c\u4f7f\u5f00\u53d1\u8005\u80fd\u591f\u5728\u5ba2\u6237\u7aef\u4fa7\u4f7f\u7528\u811a\u672c\u3001Java\u4e0e\u539f\u751f\u4ee3\u7801\u6269\u5c55\u73a9\u6cd5\u4e0e\u754c\u9762\u80fd\u529b\u3002</p>\n<h2>\u5b9a\u4f4d</h2>\n<p>InnerCore\u5c5e\u4e8e\u5386\u53f2\u793e\u533a\u751f\u6001\uff0c\u4e0d\u5c5e\u4e8eM...</p>", "image": "https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/client/innercore.png", "date_modified": "2026-05-24T04:50:31+00:00", "date_published": "2026-05-24T04:50:31+00:00", "authors": [], "tags": null}, {"id": "https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/", "url": "https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/", "title": "InnerCore\u5ba2\u6237\u7aef\u6a21\u7ec4", "content_html": "<h1>InnerCore\u5ba2\u6237\u7aef\u6a21\u7ec4</h1>\n<p>\u672c\u5206\u533a\u4ee5InnerCore\u3001CoreEngine\u548cHorizon\u4e3a\u4e2d\u5fc3\uff0c\u6574\u7406Android\u5ba2\u6237\u7aef\u65e7\u6a21\u7ec4\u751f\u6001\u7684\u53ef\u6838\u9a8c\u8d44\u6599\u3002Nernar\u7ef4\u62a4\u7684InnerCore\u6587\u6863\u8bf4\u660e\uff0cInnerCore\u6269\u5c55Android\u7248Minecraft\u7684\u57fa\u7840\u529f\u80fd\uff0c\u7528\u4e8e\u521b\u5efa\u4f1a\u6539\u53d8\u73a9\u6cd5\u7684\u6a21\u7ec4\uff1b\u5b83\u7684\u601d\u8def\u4e0eBloc...</p>", "image": "https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/clients/innercore/index.png", "date_modified": "2026-05-24T04:50:31+00:00", "date_published": "2026-05-24T04:50:31+00:00", "authors": [], "tags": null}, {"id": "https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/environment-and-structure/", "url": "https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/environment-and-structure/", "title": "\u51c6\u5907\u73af\u5883\u4e0e\u9879\u76ee\u7ed3\u6784", "content_html": "<h1>\u51c6\u5907\u73af\u5883\u4e0e\u9879\u76ee\u7ed3\u6784</h1>\n<p>ICMod\u5f00\u53d1\u4ee5Android\u8bbe\u5907\u4e0a\u7684Horizon\u542f\u52a8\u5668\u4e3a\u5165\u53e3\u3002Nernar\u7ef4\u62a4\u7684InnerCore\u6587\u6863\u628a\u6574\u4f53\u5173\u7cfb\u63cf\u8ff0\u4e3a\u201cHorizon\u52a0\u8f7dInnerCore\u5305\uff0cInnerCore\u5305\u52a0\u8f7dCoreEngine\uff0c\u6a21\u7ec4\u518d\u901a\u8fc7CoreEngine\u4e0eMinecraft\u4ea4\u4e92\u201d\u3002\u8fd9\u4e2a\u4f53\u7cfb\u5c5e\u4e8e\u7b2c\u4e09\u65b9\u65e7...</p>", "image": "https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/clients/innercore/environment-and-structure.png", "date_modified": "2026-05-24T04:50:31+00:00", "date_published": "2026-05-24T04:50:31+00:00", "authors": [], "tags": null}, {"id": "https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/events-storage-and-multiplayer/", "url": "https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/events-storage-and-multiplayer/", "title": "\u4e8b\u4ef6\u3001\u5b58\u50a8\u4e0e\u591a\u4eba", "content_html": "<h1>\u4e8b\u4ef6\u3001\u5b58\u50a8\u4e0e\u591a\u4eba</h1>\n<p>InnerCore\u7684\u8fd0\u884c\u903b\u8f91\u4e3b\u8981\u56f4\u7ed5\u56de\u8c03\u3001\u53ef\u66f4\u65b0\u5bf9\u8c61\u3001\u4fdd\u5b58\u4f5c\u7528\u57df\u548c\u7f51\u7edc\u5305\u7ec4\u7ec7\u3002\u8d44\u6599\u5c06\u8fd9\u4e9b\u673a\u5236\u7528\u4e8e\u65e7Android\u5ba2\u6237\u7aef\u6a21\u7ec4\u4e2d\u7684\u4ea4\u4e92\u3001\u957f\u671f\u673a\u5236\u3001\u914d\u7f6e\u4fdd\u5b58\u548c\u591a\u4eba\u540c\u6b65\u3002</p>\n<p>/// warning | \u670d\u52a1\u7aef\u6743\u5a01\u539f\u5219\nInnerCore\u8d44\u6599\u628a\u5355\u4eba\u4e16\u754c\u7684\u4e3b\u673a\u4e5f\u89c6\u4f5c\u670d\u52a1\u7aef\u3002\u6240\u6709\u4f1a\u5f71\u54cd\u4e16\u754c\u3001\u73a9\u5bb6\u6570\u636e\u6216\u91cd...</p>", "image": "https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/clients/innercore/events-storage-and-multiplayer.png", "date_modified": "2026-05-24T04:50:31+00:00", "date_published": "2026-05-24T04:50:31+00:00", "authors": [], "tags": null}, {"id": "https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/items-blocks-and-recipes/", "url": "https://miemiemethod.github.io/bedrock-docs/guides/clients/innercore/items-blocks-and-recipes/", "title": "\u7269\u54c1\u3001\u65b9\u5757\u4e0e\u914d\u65b9", "content_html": "<h1>\u7269\u54c1\u3001\u65b9\u5757\u4e0e\u914d\u65b9</h1>\n<p>InnerCore\u7684\u7269\u54c1\u3001\u65b9\u5757\u4e0e\u914d\u65b9\u7cfb\u7edf\u4f7f\u7528JavaScript\u6216TypeScript\u811a\u672c\u6ce8\u518c\u5185\u5bb9\uff0c\u5e76\u7531\u8d44\u6e90\u76ee\u5f55\u63d0\u4f9b\u7eb9\u7406\u3002\u8fd9\u91cc\u7684\u80fd\u529b\u5c5e\u4e8e\u65e7\u7b2c\u4e09\u65b9\u5ba2\u6237\u7aef\u6a21\u7ec4\u751f\u6001\uff0c\u4e0d\u662f\u56fd\u9645\u7248\u9644\u52a0\u5305\u539f\u751f\u683c\u5f0f\u3002</p>\n<p>/// warning | \u4e0d\u8981\u6df7\u6dc6\u5f00\u53d1\u4f53\u7cfb\n\u672c\u6587\u51fa\u73b0\u7684<code>IDRegistry</c