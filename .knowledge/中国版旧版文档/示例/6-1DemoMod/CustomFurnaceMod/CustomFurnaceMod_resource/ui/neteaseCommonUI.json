        "type": "panel",
        "anchor_to": "bottom_middle",
        "anchor_from": "bottom_middle",
        "size": [
            "100%c",
            "100%c"
        ],
        "offset": "$offset",
        "layer": 30,
        "$offset|default": [
            0,
            "-16px"
        ],
        "controls": [
            {
                "itemDetailBg": {
                    "type": "image",
                    "size": [
                        "100%c + 8px",
                        "100%c + 8px"
                    ],
                    "layer": 30,
                    "bindings": [
                        {
                            "binding_condition": "always_when_visible",
                            "binding_name": "#itemDetailAlpha",
                            "binding_name_override": "#alpha"
                        }
                    ],
                    "alpha": "#itemDetailAlpha",
                    "texture": "textures/ui/detail_bg",
                    "nineslice_size": 4,
                    "controls": [
                        {
                            "itemDetailText": {
                                "bindings": [
                                    {
                                        "binding_condition": "always_when_visible",
                                        "binding_name": "#itemDetailAlpha",
                                        "binding_name_override": "#alpha"
                                    }
                                ],
                                "type": "label",
                                "layer": 1,
                                "alpha": "#itemDetailAlpha",
                                "text": ""
                            }
                        }
                    ]
                }
            }
        ]
