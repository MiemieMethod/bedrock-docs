								"up": {"uv": [6, 6], "uv_size": [-4, -6]},
								"down": {"uv": [2, 0], "uv_size": [4, 6]}
							}
						}
					]
				},
				{
					"name": "south",
					"pivot": [0, 0, 0],
					"enable": "query.is_connect(3)",
					"cubes": [
						{
							"origin": [-10, 6, 10],
							"size": [4, 4, 6],
							"uv": {
								"east": {"uv": [0, 2], "uv_size": [6, 4]},
								"west": {"uv": [0, 2], "uv_size": [6, 4]},
								"up": {"uv": [6, 6], "uv_size": [-4, -6]},
								"down": {"uv": [2, 0], "uv_size": [4, 6]}
							}
						}
					]
				},
				{
					"name": "east",
					"pivot": [0, 0, 0],
					"enable": "query.is_connect(5)",
					"cubes": [
						{
							"origin": [-16, 6, 6],
							"size": [6, 4, 4],
							"uv": {
								"north": {"uv": [0, 2], "uv_size": [6, 4]},
								"south": {"uv": [0, 2], "uv_size": [6, 4]},
								"up": {"uv": [6, 6], "uv_size": [-6, -4]},
								"down": {"uv": [0, 2], "uv_size": [6, 4]}
							}
						}
					]
				},
				{
					"name": "west",
					"pivot": [0, 0, 0],
					"enable": "query.is_connect(4)",
					"cubes": [
						{
							"origin": [-6, 6, 6],
							"size": [6, 4, 4],
							"uv": {
								"north": {"uv": [0, 2], "uv_size": [6, 4]},
								"south": {"uv": [0, 2], "uv_size": [6, 4]},
								"up": {"uv": [6, 6], "uv_size": [-6, -4]},
								"down": {"uv": [0, 2], "uv_size": [6, 4]}
