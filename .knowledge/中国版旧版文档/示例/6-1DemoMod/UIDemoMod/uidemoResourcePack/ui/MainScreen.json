{
   "default": {
      "is_new_nine_slice": "$is_new_nine_slice",
      "layer": "$texture_layer",
      "nine_slice_buttom": "$nine_slice_buttom",
      "nine_slice_left": "$nine_slice_left",
      "nine_slice_right": "$nine_slice_right",
      "nine_slice_top": "$nine_slice_top",
      "nineslice_size": "$nineslice_size",
      "texture": "$default_texture",
      "type": "image"
   },
   "hover": {
      "is_new_nine_slice": "$is_new_nine_slice",
      "layer": "$texture_layer",
      "nine_slice_buttom": "$nine_slice_buttom",
      "nine_slice_left": "$nine_slice_left",
      "nine_slice_right": "$nine_slice_right",
      "nine_slice_top": "$nine_slice_top",
      "nineslice_size": "$nineslice_size",
      "texture": "$hover_texture",
      "type": "image"
   },
   "pressed": {
      "is_new_nine_slice": "$is_new_nine_slice",
      "layer": "$texture_layer",
      "nine_slice_buttom": "$nine_slice_buttom",
      "nine_slice_left": "$nine_slice_left",
      "nine_slice_right": "$nine_slice_right",
      "nine_slice_top": "$nine_slice_top",
      "nineslice_size": "$nineslice_size",
      "texture": "$pressed_texture",
      "type": "image"
   },
   "button_label": {
      "color": "$label_color",
      "font_scale_factor": "$label_font_scale_factor",
      "font_size": "$label_font_size",
      "font_type": "smooth",
      "layer": "$label_layer",
      "max_size": ["100%", "100%"],
      "offset": "$label_offset",
      "shadow": false,
      "text": "$label_text",
      "text_alignment": "center",
      "type": "label"
   },
   "closeBtn@common.button": {
      "$label_color": [1, 1, 1],
      "$label_font_scale_factor": 1.0,
      "$label_font_size": "normal",
      "$label_layer": 10,
      "$label_offset": [0, 0],
      "$label_text": "pop screen",
      "$default_texture": "textures/netease/common/button/default",
      "$hover_texture": "textures/netease/common/button/hover",
      "$is_new_nine_slice": true,
      "$nineslice_size": [0, 0, 0, 0],
      "$nine_slice_buttom": 0,
      "$nine_slice_left": 0,
      "$nine_slice_right": 0,
      "$nine_slice_top": 0,
      "$pressed_button_name": "",
      "$default_text_color": [0.26, 0.26, 0.26],
      "$pressed_text_color": [1, 1, 1],
      "$hover_text_color": [1, 1, 1],
      "$pressed_texture": "textures/netease/common/button/pressed",
      "$texture_layer": 2,
      "anchor_from": "top_right",
      "anchor_to": "top_right",
      "controls": [{
            "default@MainScreen.default": {}
         },
         {
            "hover@MainScreen.hover": {}
         },
         {
            "pressed@MainScreen.pressed": {}
         },
         {
            "button_label@MainScreen.button_label": {}
         }
      ],
      "default_control": "default",
      "hover_control": "hover",
      "is_handle_button_move_event": true,
      "layer": 5,
      "offset": [-4, 2],
      "pressed_control": "pressed",
      "size": [80.0, 24.0],
      "type": "button",
      "visible": true
   },
   "pushBtn@common.button": {
      "$label_color": [1, 1, 1],
      "$label_font_scale_factor": 1.0,
      "$label_font_size": "normal",
      "$label_layer": 10,
      "$label_offset": [0, 0],
      "$label_text": "pushscreen",
      "$default_texture": "textures/netease/common/button/default",
      "$hover_texture": "textures/netease/common/button/hover",
      "$is_new_nine_slice": true,
      "$nineslice_size": [0, 0, 0, 0],
      "$nine_slice_buttom": 0,
      "$nine_slice_left": 0,
      "$nine_slice_right": 0,
      "$nine_slice_top": 0,
      "$pressed_button_name": "",
      "$default_text_color": [0.26, 0.26, 0.26],
      "$pressed_text_color": [1, 1, 1],
      "$hover_text_color": [1, 1, 1],
      "$pressed_texture": "textures/netease/common/button/pressed",
      "$texture_layer": 2,
      "anchor_from": "center",
      "anchor_to": "center",
      "controls": [{
            "default@MainScreen.default": {}
         },
         {
            "hover@MainScreen.hover": {}
         },
         {
            "pressed@MainScreen.pressed": {}
         },
         {
            "button_label@MainScreen.button_label": {}
         }
      ],
      "default_control": "default",
      "hover_control": "hover",
      "is_handle_button_move_event": true,
      "layer": 5,
      "offset": [-4, -20],
      "pressed_control": "pressed",
      "size": [100.0, 30.0],
      "type": "button",
      "visible": true
   },
   "gridExplain": {
      "anchor_from": "center",
      "anchor_to": "center",
      "color": [1, 1, 1],
      "font_scale_factor": 1.169999957084656,
      "font_size": "normal",
      "font_type": "smooth",
      "layer": 42,
      "offset": [7.0, 96.0],
      "shadow": false,
      "size": [249.60, 100.0],
      "text": "说明：该场景演示了PushScreen/PopScreen的简单用法",
      "text_alignment": "center",
      "type": "label",
      "visible": true
   },

   "mainPanel": {
      "layer": 1000,
      "type": "panel",
      "size": ["100%", "100.0%"],
      "controls": [{
            "closeBtn@MainScreen.closeBtn": {}
         },
         {
            "gridExplain@MainScreen.gridExplain": {}
         },
         {
            "pushBtn@MainScreen.pushBtn": {}
         }
      ]
   },
   "main": {
      "absorbs_input": true,
      "always_accepts_input": false,
      "controls": [{
         "mainPanel@MainScreen.mainPanel": {}
      }],
      "force_render_below": false,
      "is_showing_menu": true,
      "render_game_behind": true,
      "render_only_when_topmost": true,
      "should_steal_mouse": false,
      "type": "screen"
   },
   "namespace": "MainScreen"
}