                    "x-regex-flags": "ECMAScript,icase"
                },
                "options": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/476920027"
                    },
                    "minItems": 2,
                    "maxItems": 20
                },
                "text": {
                    "type": "string"
                },
                "type": {
                    "title": "SettingType",
                    "type": "string",
                    "enum": [
                        "label",
                        "slider",
                        "toggle",
                        "dropdown"
                    ]
