<?xml version="1.0" encoding="UTF-8" ?> <?xml-stylesheet type="text/xsl" href="rss.xsl"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:dc="http://purl.org/dc/elements/1.1/"> <channel> <title>基岩文档</title><description>Minecraft基岩版开发文档</description><link>https://miemiemethod.github.io/bedrock-docs/</link><atom:link href="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml" rel="self" type="application/rss+xml" /> <docs>https://github.com/MiemieMethod/bedrock-docs</docs><language>zh</language> <pubDate>Sun, 24 May 2026 05:55:11 -0000</pubDate> <lastBuildDate>Sun, 24 May 2026 05:55:11 -0000</lastBuildDate> <ttl>1440</ttl> <generator>MkDocs RSS plugin - v1.19.0</generator> <image> <url>None</url> <title>基岩文档</title> <link>https://miemiemethod.github.io/bedrock-docs/</link> </image> <item> <title>技术</title> <description>&lt;h1&gt;技术&lt;/h1&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/blog/category/%E6%8A%80%E6%9C%AF/</link> <pubDate>Sun, 24 May 2026 06:00:26 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/blog/category/%E6%8A%80%E6%9C%AF/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/blog/category/技术.png" type="image/png" length="10425" /> </item> <item> <title>2024</title> <description>&lt;h1&gt;2024&lt;/h1&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/blog/archive/2024/</link> <pubDate>Sun, 24 May 2026 06:00:26 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/blog/archive/2024/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/blog/archive/2024.png" type="image/png" length="12772" /> </item> <item> <title>JSON UI</title> <description>&lt;h1&gt;JSON UI&lt;/h1&gt; &lt;p&gt;&lt;strong&gt;JSON UI&lt;/strong&gt;是Minecraft基岩版中用于定义游戏用户界面的系统。该系统使用JSON格式的数据文件声明界面的布局、控件和交互逻辑，允许资源包覆盖或扩展游戏内界面。&lt;/p&gt; &lt;p&gt;JSON UI没有独立的格式版本控制，更新时应始终以目标版本原版&lt;code&gt;ui/&lt;/code&gt;文件与内容日志为准。&lt;/p&gt; &lt;h2&gt;概述&lt;/h2&gt; &lt;p&gt;基...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/general/json-ui/</link> <pubDate>Sun, 24 May 2026 05:53:01 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/general/json-ui/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/general/json-ui.png" type="image/png" length="15581" /> </item> <item> <title>微缩方块</title> <description>&lt;h1&gt;微缩方块&lt;span class=&#34;mdx-badge mdx-badge--china&#34;&gt;&lt;span class=&#34;mdx-badge__icon&#34;&gt;&lt;a href=&#34;../../help/docs/contributing.md#符号&#34; title=&#34;中国版独有&#34;&gt;:material-inbox-full:&lt;/a&gt;&lt;/span&gt;&lt;/h1&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/general/micro-block/</link> <pubDate>Sun, 24 May 2026 05:53:01 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/general/micro-block/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/general/micro-block.png" type="image/png" length="10480" /> </item> <item> <title>状态效果</title> <description>&lt;h1&gt;状态效果&lt;/h1&gt; &lt;p&gt;&lt;strong&gt;状态效果（Status Effect）&lt;/strong&gt;是Minecraft基岩版中施加于实体上的、具有持续时间和效力等级的临时性增益或减益效果。状态效果可以改变实体的属性、行为或外观，广泛应用于药水、魔咒、信标、命令等多种游戏机制中。&lt;/p&gt; &lt;h2&gt;概述&lt;/h2&gt; &lt;p&gt;每个状态效果由一个赋命名空间标识符唯一标识，并具有以下...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/general/status-effect/</link> <pubDate>Sun, 24 May 2026 05:53:01 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/general/status-effect/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/general/status-effect.png" type="image/png" length="10480" /> </item> <item> <title>模组SDK</title> <description>&lt;h1&gt;模组SDK&lt;span class=&#34;mdx-badge mdx-badge--china&#34;&gt;&lt;span class=&#34;mdx-badge__icon&#34;&gt;&lt;a href=&#34;../../../help/docs/contributing.md#符号&#34; title=&#34;中国版独有&#34;&gt;:material-inbox-full:&lt;/a&gt;&lt;/span&gt;&amp;lt;/...&lt;/h1&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/addons/modsdk/</link> <pubDate>Sun, 24 May 2026 05:53:01 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/addons/modsdk/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/addons/modsdk/index.png" type="image/png" length="35298" /> </item> <item> <title>制作中国版模组SDK界面</title> <description>&lt;h1&gt;制作中国版模组SDK界面&lt;span class=&#34;mdx-badge mdx-badge--china&#34;&gt;&lt;span class=&#34;mdx-badge__icon&#34;&gt;&lt;a href=&#34;../../../help/docs/contributing.md#符号&#34; title=&#34;中国版独有&#34;&gt;:material-inbox-full:&lt;/a&gt;&amp;lt;/...&lt;/h1&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/addons/modsdk/custom-ui/</link> <pubDate>Sun, 24 May 2026 05:53:01 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/addons/modsdk/custom-ui/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/addons/modsdk/custom-ui.png" type="image/png" length="16149" /> </item> <item> <title>中国版旧版文档归档</title> <description>&lt;h1&gt;中国版旧版文档归档&lt;/h1&gt; &lt;p&gt;/// details-info | 署名信息 - 本分区内容整理自中国版旧版开发文档历史资料与本地知识库归档。 - 原始历史入口可见：&lt;a href=&#34;http://mc.163.com/mcstudio/mc-dev/&#34;&gt;http://mc.163.com/mcstudio/mc-dev/&lt;/a&gt; - 本分区以“保留原文脉络”为目标，主要用于旧项目维护与历史语境核对。 ///...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/translations/china-legacy/</link> <pubDate>Sun, 24 May 2026 05:53:01 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/translations/china-legacy/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/translations/china-legacy/index.png" type="image/png" length="10713" /> </item> <item> <title>示例与DEMO旧版目录</title> <description>&lt;h1&gt;示例与DEMO旧版目录&lt;/h1&gt; &lt;p&gt;本页用于保留&lt;code&gt;.knowledge/中国版旧版文档/4-DEMO示例&lt;/code&gt;与&lt;code&gt;.knowledge/中国版旧版文档/示例&lt;/code&gt;中的原文脉络。它主要用于回答“旧版教程里提到的Demo到底是哪一个”。&lt;/p&gt; &lt;h2&gt;示例索引页&lt;/h2&gt; &lt;ul&gt; &lt;li&gt;&lt;code&gt;4-DEMO示例/示例简介&lt;/code&gt;&lt;/li&gt; &lt;/ul&gt; &lt;p&gt;该页汇总了旧版中国版文档中提到的主...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/translations/china-legacy/demos/</link> <pubDate>Sun, 24 May 2026 05:53:01 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/translations/china-legacy/demos/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/translations/china-legacy/demos.png" type="image/png" length="16282" /> </item> <item> <title>ModSDK旧版教程目录</title> <description>&lt;h1&gt;ModSDK旧版教程目录&lt;/h1&gt; &lt;p&gt;本页用于保留&lt;code&gt;.knowledge/中国版旧版文档/2-ModSDK模组开发&lt;/code&gt;目录中“教程与流程类”资料的原文脉络。接口清单类内容已并入参考分区，不在本页重复展开。&lt;/p&gt; &lt;h2&gt;顶层主题&lt;/h2&gt; &lt;ul&gt; &lt;li&gt;&lt;code&gt;01-Mod开发简介&lt;/code&gt;&lt;/li&gt; &lt;li&gt;&lt;code&gt;02-Python脚本开发/0-脚本开发入门&lt;/code&gt;&lt;/li&gt; &lt;li&gt;`03-...&lt;/li&gt; &lt;/ul&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/translations/china-legacy/modsdk/</link> <pubDate>Sun, 24 May 2026 05:53:01 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/translations/china-legacy/modsdk/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/translations/china-legacy/modsdk.png" type="image/png" length="20066" /> </item> <item> <title>社区模组系列教程</title> <description>&lt;h1&gt;社区模组系列教程&lt;/h1&gt; &lt;p&gt;这里收录旧版或社区维护的基岩版客户端模组生态。它们通常不属于Mojang当前官方支持的附加包体系，也不等同于服务器插件。阅读这一部分时，请先接受一个现实：很多旧生态依赖特定Android版本、特定Minecraft版本或已经停止维护的加载器，更适合作为历史资料、旧模组维护资料或迁移参考。 ...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/community-mods/</link> <pubDate>Sun, 24 May 2026 05:44:33 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/community-mods/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/community-mods/index.png" type="image/png" length="10747" /> </item> <item> <title>文档</title> <description>&lt;h1&gt;文档&lt;/h1&gt; &lt;p&gt;这里为Minecraft基岩版开发者提供了一系列的文档。文档围绕各类概念与主体展开，以较为正式的语气和说明性的体裁呈现。本站正在持续补充更多条目，以便覆盖开发Minecraft基岩版内容时需要理解的主要概念。&lt;/p&gt; &lt;p&gt;本文档主要回答“是什么”和“为什么”。需要了解实际制作步骤时，请查看教程；需要查阅字段、参...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/</link> <pubDate>Sun, 24 May 2026 05:44:16 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/index.png" type="image/png" length="10425" /> </item> <item> <title>纹理</title> <description>&lt;h1&gt;纹理&lt;/h1&gt; &lt;p&gt;&lt;strong&gt;纹理（Texture）&lt;/strong&gt;是Minecraft基岩版中定义游戏视觉表现的二维图像资源。纹理应用于方块表面、实体模型、物品图标、粒子特效、用户界面等几乎所有可视化元素，是资源包中最核心的资源类型之一。&lt;/p&gt; &lt;h2&gt;概述&lt;/h2&gt; &lt;p&gt;基岩版中的纹理通常为PNG格式的图像文件，支持透明通道（Alpha通道）。纹理的分...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/addon/texture/</link> <pubDate>Sun, 24 May 2026 05:44:16 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/addon/texture/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/addon/texture.png" type="image/png" length="10425" /> </item> <item> <title>InnerCore</title> <description>&lt;h1&gt;InnerCore&lt;/h1&gt; &lt;p&gt;&lt;strong&gt;InnerCore（InnerCore）&lt;/strong&gt;是面向Android版Minecraft基岩版的传统客户端模组框架。其核心目标是为第三方模组提供统一运行层，使开发者能够在客户端侧使用脚本、Java与原生代码扩展玩法与界面能力。&lt;/p&gt; &lt;h2&gt;定位&lt;/h2&gt; &lt;p&gt;InnerCore属于历史社区生态，不属于M...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/client/innercore/</link> <pubDate>Sun, 24 May 2026 05:44:16 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/client/innercore/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/client/innercore.png" type="image/png" length="15017" /> </item> <item> <title>LeviLamina客户端模组</title> <description>&lt;h1&gt;LeviLamina客户端模组&lt;/h1&gt; &lt;p&gt;&lt;strong&gt;LeviLamina客户端模组（LeviLamina Client Mod）&lt;/strong&gt;是基于LeviLamina客户端构建的原生扩展形态。该形态通过PreLoader将LeviLamina客户端构建加载到受支持的Windows版Minecraft客户端进程，并由LeviLami...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/client/levilamina-client/</link> <pubDate>Sun, 24 May 2026 05:44:16 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/client/levilamina-client/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/client/levilamina-client.png" type="image/png" length="16865" /> </item> <item> <title>ModPE</title> <description>&lt;h1&gt;ModPE&lt;/h1&gt; &lt;p&gt;&lt;strong&gt;ModPE（ModPE Script）&lt;/strong&gt;是早期Android版Minecraft基岩版社区中用于客户端脚本扩展的一类接口体系，主要与BlockLauncher等启动器生态相关。其核心价值是以较低门槛在客户端侧注入脚本逻辑，用于修改交互、界面与部分玩法行为。&lt;/p&gt; &lt;h2&gt;定位&lt;/h2&gt; &lt;p&gt;ModPE属于历...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/client/modpe/</link> <pubDate>Sun, 24 May 2026 05:44:16 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/client/modpe/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/client/modpe.png" type="image/png" length="14139" /> </item> <item> <title>图集</title> <description>&lt;h1&gt;图集&lt;/h1&gt; &lt;p&gt;&lt;strong&gt;图集（Atlas）&lt;/strong&gt;是将多张二维图像按规则打包并统一索引的一种资源组织机制。在Minecraft基岩版中，图集用于管理方块、物品及部分界面渲染所需的纹理条目，是资源包纹理系统的核心结构之一。&lt;/p&gt; &lt;h2&gt;核心作用&lt;/h2&gt; &lt;p&gt;图集将原本分散的纹理资源合并到统一的渲染页中，主要作用包括：&lt;/p&gt; &lt;ul&gt; &lt;li&gt;减少渲染阶段的纹...&lt;/li&gt; &lt;/ul&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/general/atlas/</link> <pubDate>Sun, 24 May 2026 05:44:16 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/general/atlas/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/general/atlas.png" type="image/png" length="10425" /> </item> <item> <title>模组</title> <description>&lt;h1&gt;模组&lt;/h1&gt; &lt;p&gt;&lt;strong&gt;模组（Mod&lt;/strong&gt;，全称&lt;strong&gt;Modification）&lt;/strong&gt;是指由第三方玩家或团队制作的可以针对原版游戏进行修改的游戏内容，可以是新的物品、生物、地图、任务、剧情、音乐、动画、界面等等。模组可以对游戏进行扩展、修改、优化、美化、增加新内容等等。模组不区分大小，可以是一个简单的小功能，也可以是一个庞大的...&lt;/p&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/docs/general/mod/</link> <pubDate>Sun, 24 May 2026 05:44:16 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/docs/general/mod/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/docs/general/mod.png" type="image/png" length="10425" /> </item> <item> <title>教程</title> <description>&lt;h1&gt;教程&lt;/h1&gt; &lt;p&gt;这里提供了有关Minecraft基岩版技术开发的各种教程。如果你对想要开发的领域不知道该怎么开始以及怎么进行下去，你可以参考本页面中列出的教程，以下内容将引导你在不同技术领域进行开发学习。&lt;/p&gt; &lt;div class=&#34;grid cards&#34; markdown&gt; - :material-earth:...</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/</link> <pubDate>Sun, 24 May 2026 05:44:16 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/index.png" type="image/png" length="10425" /> </item> <item> <title>国际版开发入门</title> <description>&lt;h1&gt;国际版开发入门&lt;span class=&#34;mdx-badge mdx-badge--vanilla&#34;&gt;&lt;span class=&#34;mdx-badge__icon&#34;&gt;&lt;a href=&#34;../help/docs/contributing.md#符号&#34; title=&#34;国际版独有&#34;&gt;:material-inbox-full:&lt;/a&gt;&lt;/span&gt;&lt;/h1&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/guides/international-getting-started/</link> <pubDate>Sun, 24 May 2026 05:44:16 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/guides/international-getting-started/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/guides/international-getting-started.png" type="image/png" length="10639" /> </item> </channel> </rss>