<?xml version="1.0" encoding="UTF-8" ?> <?xml-stylesheet type="text/xsl" href="rss.xsl"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:dc="http://purl.org/dc/elements/1.1/"> <channel> <title>基岩文档</title><description>Minecraft基岩版开发文档</description><link>https://miemiemethod.github.io/bedrock-docs/</link><atom:link href="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml" rel="self" type="application/rss+xml" /> <docs>https://github.com/MiemieMethod/bedrock-docs</docs><language>zh</language> <pubDate>Sun, 24 May 2026 06:57:50 -0000</pubDate> <lastBuildDate>Sun, 24 May 2026 06:57:50 -0000</lastBuildDate> <ttl>1440</ttl> <generator>MkDocs RSS plugin - v1.19.0</generator> <image> <url>None</url> <title>基岩文档</title> <link>https://miemiemethod.github.io/bedrock-docs/</link> </image> <item> <title>技术</title> <description>&lt;h1&gt;技术&lt;/h1&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/blog/category/%E6%8A%80%E6%9C%AF/</link> <pubDate>Sun, 24 May 2026 06:59:49 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/blog/category/%E6%8A%80%E6%9C%AF/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/blog/category/技术.png" type="image/png" length="10425" /> </item> <item> <title>2024</title> <description>&lt;h1&gt;2024&lt;/h1&gt;</description> <link>https://miemiemethod.github.io/bedrock-docs/blog/archive/2024/</link> <pubDate>Sun, 24 May 2026 06:59:49 +0000</pubDate> <source url="https://miemiemethod.github.io/bedrock-docs/feed_rss_updated.xml">基岩文档</source><guid isPermaLink="true">https://miemiemethod.github.io/bedrock-docs/blog/archive/2024/</guid> <enclosure url="https://miemiemethod.github.io/bedrock-docs/assets/images/social/blog/archive/2024.png" type="image/png" length="12772" /> </item> <item> <title>模组SDK</title> <description>&lt;h1&gt;模组SDK&lt;span class=&#